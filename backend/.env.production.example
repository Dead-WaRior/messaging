# Production example — copy to .env on host
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"
JWT_SECRET="generate-a-long-random-string-and-keep-it-secret"
JWT_EXPIRES_IN="7d"
PORT=3000
# Restrict this to your frontend origin in production, e.g. https://your-app.onrender.com
CORS_ORIGIN="*"
